{
  "name": "nexus-browser",
  "version": "1.0.0",
  "description": "Nexus Browser - navegador com IA e segurança",
  "author": "Jose Lucas",
  "main": "main.js",

  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },

  "build": {
    "appId": "com.nexus.browser",
    "productName": "Nexus Browser",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/logo.png"
    }
  },

  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  }
}
